# Azure OpenAI — all four are required
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5-nano
# IMPORTANT: gpt-5-nano is a reasoning model and needs a recent preview API version.
# 2025-04-01-preview is confirmed working. Older stable versions (e.g. 2024-02-01) 404.
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# AQI data — WAQI is primary, OpenAQ needs no key
WAQI_TOKEN=your_waqi_token_here

# Weather. Also supplies wind DIRECTION, which the enforcement scorer uses to
# decide which registered sources are upwind of a hotspot — without it,
# candidates are ranked on distance alone.
OPENWEATHER_API_KEY=your_owm_key_here

# NASA FIRMS — satellite active-fire detection (OPTIONAL).
# Free key: https://firms.modaps.eosdis.nasa.gov/api/area/
# Surfaces open waste/biomass burning, which is illegal and therefore absent
# from any ground register, so satellite observation is the only way it enters
# the enforcement candidate set. Purely additive: without a key the Enforcement
# Agent falls back to the OSM-derived registry alone and still works.
FIRMS_MAP_KEY=
# VIIRS at 375 m resolves small urban fires better than MODIS at 1 km.
FIRMS_SOURCE=VIIRS_SNPP_NRT
# Detection window in days. FIRMS accepts 1-10, but over a large bounding box
# the bigger windows silently return an empty body instead of an error (7 and 10
# both yielded nothing where 3 yielded 138 detections). Do not raise this above 3.
FIRMS_DAY_RANGE=3
